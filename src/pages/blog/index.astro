---
import Post from "@/components/Post.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import Pagination from "@/layouts/components/Pagination.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import { markdownify, plainify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const { summary_length } = config.settings;
const postIndex = (await getEntry("blog", "-index")) as CollectionEntry<"blog">;

if (postIndex?.data?.draft) {
  return Astro.redirect("/404");
}

const posts = await getSinglePage("blog");
const sortedPosts = sortByDate(posts);
const totalPages = Math.ceil(posts.length / config.settings.pagination);
const currentPosts = sortedPosts.slice(0, config.settings.pagination);
const featuredPost = currentPosts[0];
const hasPosts = currentPosts.length > 0;
const siteUrl = config.site.base_url.replace(/\/$/, "");
const blogIndexJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: postIndex?.data.meta_title || postIndex?.data.title,
  description: postIndex?.data.description || config.metadata.meta_description,
  url: `${siteUrl}/blog`,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: currentPosts.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `${siteUrl}/blog/${post.id}`,
      name: post.data.title,
    })),
  },
};
---

<Base
  title={postIndex?.data.title}
  meta_title={postIndex?.data.meta_title}
  description={postIndex?.data.description}
  image={postIndex?.data.image}
  structured_data={blogIndexJsonLd}
>
  <section class="section">
    <div class="container">
      <h1
        class="text-center font-normal lg:text-[56px]"
        set:html={markdownify(postIndex?.data.title)}
      />
      <div class="row pb-12">
        {
          hasPosts ? (
            <>
              <div class="row col-12 pb-24 pt-16">
                <div class="md:col-6">
                  {
                    featuredPost.data.image && (
                      <Image
                        class="blog-index-image mx-auto"
                        src={featuredPost.data.image}
                        alt={featuredPost.data.title}
                        width={450}
                        height={250}
                      />
                    )
                  }
                </div>
                <div class="md:col-6">
                  {
                    featuredPost.data.categories?.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {featuredPost.data.categories.map((category: string) => (
                          <span class="rounded-full bg-light px-3 py-1 text-xs font-semibold uppercase tracking-wide text-text">
                            {category}
                          </span>
                        ))}
                      </div>
                    )
                  }
                  <h2 class="h3 mb-2 mt-4">
                    <a
                      href={`/blog/${featuredPost.id}`}
                      class="block hover:text-primary"
                    >
                      {featuredPost.data.title}
                    </a>
                  </h2>
                  <p set:html={plainify(featuredPost.body.slice(0, summary_length))} />
                  <a class="btn btn-primary mt-4" href={`/blog/${featuredPost.id}`} rel="">
                    Read More
                  </a>
                </div>
              </div>
              {
                currentPosts.slice(1).map((post) => (
                  <div class="col-12 mb-8 sm:col-6 lg:col-4">
                    <Post post={post} />
                  </div>
                ))
              }
            </>
          ) : (
            <div class="col-12 py-16">
              <div class="mx-auto max-w-[720px] rounded-[20px] border border-border bg-white/80 px-6 py-10 text-center shadow-[0_24px_60px_-46px_rgba(23,20,58,.35)]">
                <h2 class="h4">No blog posts published yet</h2>
                <p class="mt-3 text-text">
                  The blog archive is currently empty.
                </p>
              </div>
            </div>
          )
        }
      </div>
      {hasPosts && <Pagination section={"blog"} currentPage={1} totalPages={totalPages} />}
    </div>
  </section>
</Base>
