---
import { Image } from "astro:assets";
import Base from "@/layouts/Base.astro";
import ActionButton from "@/layouts/components/ActionButton.astro";
import AudienceTabs from "@/layouts/components/AudienceTabs";
import ImageCarousel from "@/layouts/components/ImageCarousel";
import RotatingText from "@/layouts/components/RotatingText";
import { markdownify } from "@/lib/utils/textConverter";
import { getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";

const homepage = (await getEntry(
  "homepage",
  "-index"
)) as CollectionEntry<"homepage">;

const {
  banner,
  audience_tabs,
  how_it_works,
  profile_highlights,
  call_to_action,
  testimonial,
} = homepage.data;
---

<Base>
  <section class="hero-pattern section pb-12 pt-8 md:pt-14">
    <div class="container">
      <div class="mx-auto max-w-[920px] text-center">
        <h1 class="mx-auto max-w-[920px] text-[2.2rem] leading-[1.05] md:text-[3.6rem]">
          <span set:html={banner?.title} />
          {
            banner?.rotating_phrases?.length ? (
              <>
                <br />
                <span class="hero-rotator-wrap">
                  <RotatingText phrases={banner.rotating_phrases} client:load />
                </span>
              </>
            ) : null
          }
        </h1>

        {
          banner?.content && (
            <div
              class="mx-auto mt-6 max-w-[720px] text-base leading-8 md:text-lg"
              set:html={markdownify(banner.content, true)}
            />
          )
        }

        {
          banner?.subtitle && (
            <p
              class="mx-auto mt-4 max-w-[680px] font-secondary text-base font-semibold text-text-dark"
              set:html={markdownify(banner.subtitle)}
            />
          )
        }

        {banner?.note && <p class="mt-3 text-sm italic text-secondary">{banner.note}</p>}

        {
          banner?.button?.enable && (
            <div class="mt-6">
              <ActionButton
                variant="outline-primary"
                href={banner.button.link}
                label={banner.button.label}
              />
            </div>
          )
        }
      </div>
    </div>
  </section>

  {
    audience_tabs?.items?.length && (
      <section class="section bg-white/65 py-10 md:py-12 backdrop-blur-[1px]">
        <div class="container">
          <AudienceTabs items={audience_tabs.items} client:load />
        </div>
      </section>
    )
  }

  {
    how_it_works && (
      <section class="section bg-transparent">
        <div class="container grid items-center gap-10 lg:grid-cols-2">
          <div>
            {how_it_works.eyebrow && <p class="eyebrow">{how_it_works.eyebrow}</p>}
            <h2 class="max-w-[560px]" set:html={how_it_works.title} />

            <div class="step-list mt-6 space-y-4">
              {how_it_works.steps.map((step) => (
                <div class="step-list-item">
                  <p class="font-primary text-lg font-semibold text-text-dark">{step.title}</p>
                  <p class="mt-1">{step.content}</p>
                </div>
              ))}
            </div>

            {
              how_it_works.note && (
                <p class="mt-5 max-w-[620px] font-secondary text-sm italic text-text-dark">
                  {how_it_works.note}
                </p>
              )
            }

            {
              how_it_works.button?.enable && (
                <ActionButton
                  className="mt-6"
                  href={how_it_works.button.link}
                  label={how_it_works.button.label}
                />
              )
            }
          </div>

          <div class="home-surface">
            <ImageCarousel
              images={how_it_works.images || (how_it_works.image ? [how_it_works.image] : [])}
              altPrefix="Career Clarity assessment preview"
              client:load
            />
          </div>
        </div>
      </section>
    )
  }

  {
    profile_highlights && (
      <section class="section bg-white/60 backdrop-blur-[1px]">
        <div class="container grid items-center gap-10 lg:grid-cols-2">
          <div class="order-2 lg:order-1">
            {(profile_highlights.images?.length || profile_highlights.image) && (
              <div class="home-surface">
                <ImageCarousel
                  images={profile_highlights.images || (profile_highlights.image ? [profile_highlights.image] : [])}
                  altPrefix="Career profile insight"
                  client:load
                />
              </div>
            )}
          </div>

          <div class="order-1 lg:order-2">
            <h2 class="max-w-[620px]" set:html={profile_highlights.title} />
            {
              profile_highlights.description && (
                <p class="mt-4 max-w-[620px]">{profile_highlights.description}</p>
              )
            }

            <div class="mt-6 space-y-4">
              {profile_highlights.items.map((item, index) => (
                <div class="profile-point">
                  <div class="profile-point-number">{index + 1}</div>
                  <div>
                    <p class="font-primary text-lg font-semibold text-text-dark">{item.title}</p>
                    <p class="mt-1">{item.content}</p>
                  </div>
                </div>
              ))}
            </div>

            {
              profile_highlights.button?.enable && (
                <ActionButton
                  className="mt-6"
                  href={profile_highlights.button.link}
                  label={profile_highlights.button.label}
                />
              )
            }
          </div>
        </div>
      </section>
    )
  }

  {
    call_to_action && (
      <section class="section bg-[#EEF2F7]/80 backdrop-blur-[1px]">
        <div class="container">
          <div class="mx-auto max-w-[760px] text-center">
            <h2 class="mx-auto max-w-[700px]" set:html={call_to_action.title} />
            {
              call_to_action.content && (
                <p class="mx-auto mt-4 max-w-[620px]">{call_to_action.content}</p>
              )
            }
            {
              call_to_action.button?.enable && (
                <ActionButton
                  className="mt-6"
                  href={call_to_action.button.link}
                  label={call_to_action.button.label}
                />
              )
            }
            <p class="mt-4 text-sm text-text">No credit card required. Private &amp; secure.</p>
          </div>
        </div>
      </section>
    )
  }

  {
    testimonial && (
      <section class="hero-pattern section pt-10">
        <div class="container">
          <div class="mx-auto max-w-[920px] text-center">
            {testimonial.title && <h3 class="h4">{testimonial.title}</h3>}
            <div class="mt-6 rounded-[20px] border border-border bg-white px-6 py-8 shadow-[0_24px_60px_-42px_rgba(23,20,58,0.45)] md:px-10">
              <p class="quote-mark">“</p>
              <p class="mx-auto max-w-[760px] text-base md:text-lg">{testimonial.quote}</p>
              <p class="mt-4 text-[#F3B63F]">★★★★★</p>
              {testimonial.image && (
                <Image
                  class="mx-auto mt-5 h-14 w-14 rounded-full object-cover"
                  src={testimonial.image}
                  width={112}
                  height={112}
                  alt={testimonial.author}
                />
              )}
              <p class="mt-3 font-primary text-lg font-semibold text-text-dark">{testimonial.author}</p>
              {testimonial.role && <p class="text-sm text-text">{testimonial.role}</p>}
            </div>
          </div>
        </div>
      </section>
    )
  }
</Base>
