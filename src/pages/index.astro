---
import { Image } from "astro:assets";
import Base from "@/layouts/Base.astro";
import config from "@/config/config.json";
import ActionButton from "@/layouts/components/ActionButton.astro";
import AudienceTabs from "@/layouts/components/AudienceTabs";
import ImageCarousel from "@/layouts/components/ImageCarousel";
import RotatingText from "@/layouts/components/RotatingText";
import TestimonialCard from "@/layouts/components/TestimonialCard.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";

const homepage = (await getEntry(
  "homepage",
  "-index"
)) as CollectionEntry<"homepage">;

const {
  meta_title,
  description: homepageDescription,
  image: homepageImage,
  banner,
  audience_tabs,
  how_it_works,
  profile_highlights,
  call_to_action,
  testimonial,
} = homepage.data;
const siteUrl = config.site.base_url.replace(/\/$/, "");
const homepageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: meta_title || "Kanso",
  description: homepageDescription || config.metadata.meta_description,
  url: siteUrl,
};
const webAppConfig = config.metadata.web_application;
const webApplicationJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: webAppConfig.name,
  url: siteUrl,
  applicationCategory: webAppConfig.application_category,
  operatingSystem: webAppConfig.operating_system,
  offers: {
    "@type": "Offer",
    price: webAppConfig.price,
    priceCurrency: webAppConfig.price_currency,
    description: webAppConfig.offer_description,
  },
  description: webAppConfig.description,
  audience: {
    "@type": "Audience",
    audienceType: webAppConfig.audience_type,
  },
  author: {
    "@type": "Person",
    name: webAppConfig.author_name,
    jobTitle: webAppConfig.author_job_title,
    description: webAppConfig.author_description,
    url: webAppConfig.author_url,
  },
  provider: {
    "@type": "Organization",
    name: webAppConfig.provider_name,
    url: siteUrl,
    contactPoint: {
      "@type": "ContactPoint",
      email: webAppConfig.provider_email,
    },
  },
  featureList: webAppConfig.feature_list,
  keywords: webAppConfig.keywords,
};
---

<Base
  title="Kanso"
  meta_title={meta_title}
  description={homepageDescription}
  image={homepageImage}
  structured_data={[homepageJsonLd, webApplicationJsonLd]}
>
  <section class="section pb-12 pt-8 md:pt-14">
    <div class="container">
      <div class="mx-auto max-w-[920px] text-center">
        <h1 class="mx-auto max-w-[920px] text-[1.9rem] leading-[1.03] sm:text-[2.5rem] md:text-[3.2rem] lg:text-[3.6rem]">
          <span set:html={banner?.title} />
          {
            banner?.rotating_phrases?.length ? (
              <>
                <br />
                <span class="hero-rotator-wrap">
                  <RotatingText phrases={banner.rotating_phrases} client:idle />
                </span>
              </>
            ) : null
          }
        </h1>

        {
          banner?.title_subline && (
            <p class="hero-title-subline">{banner.title_subline}</p>
          )
        }

        {
          banner?.content && (
            <div
              class="mx-auto mt-6 max-w-[720px] text-left text-base leading-8 md:text-lg"
              set:html={markdownify(banner.content, true)}
            />
          )
        }

        {
          (banner?.content_footer || banner?.subtitle) && (
            <p
              class="hero-content-footer"
              set:html={markdownify(banner?.content_footer || banner?.subtitle || "")}
            />
          )
        }

        {
          banner?.note && (
            <p class="mx-auto mt-5 max-w-[720px] text-left text-sm italic text-secondary">
              {banner.note}
            </p>
          )
        }

        {
          banner?.button?.enable && (
            <div class="mt-7">
              <ActionButton
                variant="secondary"
                href={banner.button.link}
                label={banner.button.label}
              />
            </div>
          )
        }
      </div>
    </div>
  </section>

  {
    audience_tabs?.items?.length && (
      <section class="section py-10 md:py-12">
        <div class="container">
          <AudienceTabs items={audience_tabs.items} client:idle />
        </div>
      </section>
    )
  }

  {
    how_it_works && (
      <section class="section">
        <div class="container">
          <div class="how-it-works-heading mb-8 md:mb-10">
            {how_it_works.eyebrow && <p class="eyebrow">{how_it_works.eyebrow}</p>}
            <h2 class="max-w-[760px]" set:html={how_it_works.title} />
          </div>

          <div class="grid items-center gap-10 lg:grid-cols-2">
            <div>
              <div class="step-list space-y-4">
                {how_it_works.steps.map((step, index) => (
                  <div class="step-list-item">
                    <p class="font-primary text-lg font-semibold text-text-dark">
                      <span class="mr-2 text-secondary">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      {step.title}
                    </p>
                    <p class="mt-1">{step.content}</p>
                  </div>
                ))}
              </div>

            {
              how_it_works.note && (
                <aside class="feature-note-callout mt-5 max-w-[620px]" aria-label="Key takeaway">
                  <p>{how_it_works.note}</p>
                </aside>
              )
            }

            {
              how_it_works.button?.enable && (
                <ActionButton
                  className="mt-6"
                  href={how_it_works.button.link}
                  label={how_it_works.button.label}
                />
              )
            }
          </div>

          <div class="home-surface">
            <ImageCarousel
              images={how_it_works.images || (how_it_works.image ? [how_it_works.image] : [])}
              altPrefix="Kanso assessment preview"
              minHeight="clamp(320px, 36vw, 460px)"
              client:idle
            />
          </div>
        </div>
        </div>
      </section>
    )
  }

  {
    profile_highlights && (
      <section class="section">
        <div class="container grid items-center gap-10 lg:grid-cols-2">
          <div class="order-2 lg:order-1">
            {(profile_highlights.images?.length || profile_highlights.image) && (
              <div class="home-surface">
                <ImageCarousel
                  images={profile_highlights.images || (profile_highlights.image ? [profile_highlights.image] : [])}
                  altPrefix="Career profile insight"
                  minHeight="clamp(280px, 32vw, 380px)"
                  client:idle
                />
              </div>
            )}
          </div>

          <div class="order-1 lg:order-2">
            <h2 class="max-w-[620px]" set:html={profile_highlights.title} />
            {
              profile_highlights.description && (
                <p class="mt-4 max-w-[620px]">{profile_highlights.description}</p>
              )
            }

            <div class="mt-6 space-y-4">
              {profile_highlights.items.map((item, index) => (
                <div class="profile-point">
                  <div>
                    <p class="font-primary text-lg font-semibold text-text-dark">
                      <span class="mr-2 text-secondary">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      {item.title}
                    </p>
                    <p class="mt-1">{item.content}</p>
                  </div>
                </div>
              ))}
            </div>

            {
              profile_highlights.button?.enable && (
                <ActionButton
                  className="mt-6"
                  href={profile_highlights.button.link}
                  label={profile_highlights.button.label}
                />
              )
            }
          </div>
        </div>
      </section>
    )
  }

  {
    call_to_action && (
      <section class="section">
        <div class="container">
          <div class="mx-auto max-w-[790px] text-center">
            <h2 class="mx-auto max-w-[760px]" set:html={call_to_action.title} />
            {
              call_to_action.content && (
                <p class="mx-auto mt-4 max-w-[620px]">{call_to_action.content}</p>
              )
            }
            {
              call_to_action.button?.enable && (
                <ActionButton
                  className="mt-6"
                  href={call_to_action.button.link}
                  label={call_to_action.button.label}
                />
              )
            }
            <p class="mt-4 text-sm text-text">
              No credit card required. <a href="/privacy-policy" class="underline hover:text-secondary">Private &amp; secure.</a>
            </p>
          </div>
        </div>
      </section>
    )
  }

  {
    testimonial && (
      <section class="section pt-10">
        <div class="container">
          <TestimonialCard testimonial={testimonial} headingTag="h3" />
        </div>
      </section>
    )
  }
</Base>
