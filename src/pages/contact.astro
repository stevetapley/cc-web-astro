---
import Base from "@/layouts/Base.astro";
import ActionButton from "@/layouts/components/ActionButton.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;
const { title, meta_title, description, image, info } = entry.data;
---

<Base title={title} meta_title={meta_title} description={description} image={image}>
  <section class="section pt-10 md:pt-14">
    <div class="container">
      <div class="audience-page-heading contact-page-heading">
        <h1 class="h1" set:html={markdownify(title)} />
        <p class="mt-4" set:html={markdownify(description)} />
      </div>

      <div class="contact-panel mt-10 md:mt-12">
        <div class="contact-panel-copy">
          <p class="eyebrow">Contact</p>
          <h2 set:html={markdownify(info?.title)} />
          <p class="mt-4 max-w-[560px]" set:html={markdownify(info?.description)} />

          <ul class="contact-list contact-list-modern mt-6">
            {
              info?.contacts?.map((contact) => (
                <li set:html={markdownify(contact)} />
              ))
            }
          </ul>

          <div class="mt-7 flex flex-wrap gap-3">
            <ActionButton href="/about" label="About Career Clarity" variant="outline-primary" />
          </div>
        </div>

        <aside class="waitlist-callout hidden">
          <p class="eyebrow">Coming soon</p>
          <h3 class="h4">Waitlist / early access area</h3>
          <p class="mt-3">
            This space is intentionally reserved for your future waitlist form or signup CTA.
            For now, it works as a simple placeholder that can be removed or swapped later.
          </p>
          <div class="waitlist-placeholder mt-5">
            <p class="font-primary text-base font-semibold text-text-dark">Future options</p>
            <ul class="mt-3 space-y-2 text-sm text-text">
              <li>• Waitlist signup form</li>
              <li>• Calendly / booking CTA</li>
              <li>• Early access announcement</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
