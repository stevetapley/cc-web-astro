---
import Base from "@/layouts/Base.astro";
import config from "@/config/config.json";
import { markdownify, plainify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

const entry = (await getEntry("faq", "-index")) as CollectionEntry<"faq">;

if (entry?.data?.draft) {
  return Astro.redirect("/404");
}

const { title, description, faqs } = entry.data;
const siteUrl = config.site.base_url.replace(/\/$/, "");
const faqPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  name: title,
  description,
  url: `${siteUrl}/faq`,
  mainEntity: (faqs || []).map((faq) => ({
    "@type": "Question",
    name: plainify(faq.title),
    acceptedAnswer: {
      "@type": "Answer",
      text: plainify(faq.answer),
    },
  })),
};
---

<Base
  title={title}
  description={description}
  structured_data={faqPageJsonLd}
>
  <section class="section">
    <div class="container">
      <h1 class="text-center font-normal" set:html={markdownify(title)} />
      <div class="section row -mt-6">
        {
          faqs?.map((faq) => (
            <div class="col-12 mt-6 md:col-6">
              <div class="p-12  shadow">
                <div class="faq-head relative">
                  <h4 set:html={markdownify(faq.title)} />
                </div>
                <p class="faq-body mt-4" set:html={markdownify(faq.answer)} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Base>
