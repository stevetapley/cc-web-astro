---
import Logo from "@/components/Logo.astro";
import ActionButton from "@/components/ActionButton.astro";
import { nav_button } from "@/config/config.json";
import menu from "@/config/menu.json";

const pathname = Astro.url.pathname;

const isLinkActive = (url: string) =>
  pathname === url || (url !== "/" && pathname.startsWith(`${url}/`));

const isChildActive = (children?: ChildNavigationLink[]) =>
  children?.some((child) => isLinkActive(child.url)) ?? false;

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { main }: { main: NavigationLink[] } = menu;
---

<header class="header">
  <nav class="navbar container">
    <!-- logo -->
    <div class="order-0">
      <Logo />
    </div>
    <!-- navbar toggler -->
    <input id="nav-toggle" type="checkbox" class="hidden" />
    <label
      id="show-button"
      for="nav-toggle"
      class="order-2 flex cursor-pointer items-center md:order-1 md:hidden"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Open</title>
        <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
      </svg>
    </label>
    <label
      id="hide-button"
      for="nav-toggle"
      class="order-2 cursor-pointer items-center md:order-1"
    >
      <svg class="h-6 fill-current" viewBox="0 0 20 20">
        <title>Menu Close</title>
        <polygon
          points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
          transform="rotate(45 10 10)"></polygon>
      </svg>
    </label>
    <!-- /navbar toggler -->

    <ul
      id="nav-menu"
      class="navbar-nav order-3 hidden w-full md:order-1 md:flex md:w-auto md:space-x-3"
    >
      {
        main.map((menu) => {
          const parentActive = menu.hasChildren
            ? isChildActive(menu.children)
            : isLinkActive(menu.url);

          return (
            <>
              {menu.hasChildren ? (
                <li class="nav-item">
                  <details class="nav-dropdown group relative">
                    <summary
                      class={`nav-link nav-dropdown-toggle ${
                        parentActive ? "nav-link-active" : ""
                      }`}
                    >
                      <span>{menu.name}</span>
                      <svg class="nav-dropdown-icon h-4 w-4 fill-current" viewBox="0 0 20 20">
                        <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
                      </svg>
                    </summary>

                    <ul class="nav-dropdown-list">
                      {menu.children?.map((child) => (
                        <li class="nav-dropdown-item">
                          <a
                            href={child.url}
                            data-nav-link
                            class={`nav-dropdown-link ${
                              isLinkActive(child.url) ? "nav-link-active" : ""
                            }`}
                          >
                            {child.name}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                </li>
              ) : (
                <li class="nav-item">
                  <a
                    href={menu.url}
                    data-nav-link
                    class={`nav-link block ${
                      isLinkActive(menu.url) ? "nav-link-active" : ""
                    }`}
                  >
                    {menu.name}
                  </a>
                </li>
              )}
            </>
          );
        })
      }
      {
        nav_button.enable && (
          <div class="block md:hidden">
            <ActionButton
              variant="outline-primary"
              className="z-0 ml-auto py-[14px]"
              href={nav_button.link}
              label={nav_button.label}
            />
          </div>
        )
      }
    </ul>
    {
      nav_button.enable && (
        <div class="order-1 ml-auto hidden items-center md:order-2 md:ml-0 md:flex md:min-w-[150px] lg:min-w-[200px]">
          <ActionButton
            variant="outline-primary"
            className="z-0 ml-auto py-[14px]"
            href={nav_button.link}
            label={nav_button.label}
          />
        </div>
      )
    }
  </nav>
  <script is:inline>
    if (!window.__careerClarityNavInit) {
      window.__careerClarityNavInit = true;

      const closeNavMenus = () => {
        document
          .querySelectorAll(".nav-dropdown[open]")
          .forEach((dropdown) => dropdown.removeAttribute("open"));

        const navToggle = document.getElementById("nav-toggle");
        if (navToggle && "checked" in navToggle) {
          navToggle.checked = false;
        }
      };

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;

        if (target.closest("[data-nav-link]")) {
          closeNavMenus();
        }
      });

      document.addEventListener("astro:after-swap", closeNavMenus);
    }
  </script>
</header>
