---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";

const { post } = Astro.props;
const { Content } = await render(post);
const { title, image, categories } = post.data;
---

<section class="section">
  <div class="container">
    <div class="row justify-center">
      <div class="col-12 md:col-8">
        <article class="text-center">
          {
            image && (
              <Image
                src={image}
                height={500}
                width={1000}
                alt={title}
                class="rounded-lg"
              />
            )
          }
          {
            categories?.length > 0 && (
              <div class="mt-6 flex flex-wrap gap-2 text-left">
                {categories.map((category: string) => (
                  <span class="rounded-full bg-light px-3 py-1 text-xs font-semibold uppercase tracking-wide text-text">
                    {category}
                  </span>
                ))}
              </div>
            )
          }
          <h1 set:html={markdownify(title)} class="h2 text-left my-6" />

          <div class="content mb-16 text-left">
            <Content />
          </div>
        </article>
      </div>
    </div>
  </div>
</section>
