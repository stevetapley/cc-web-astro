---
import { Image } from "astro:assets";
import config from "@/config/config.json";
import { plainify } from "@/lib/utils/textConverter";

const { post, index } = Astro.props;
const { summary_length } = config.settings;
---

<div class="post">
  {
    post.data.image && (
      <Image
        class="blog-index-image mx-auto"
        src={post.data.image}
        alt={post.data.title}
        width={450}
        height={250}
      />
    )
  }
  {
    post.data.categories?.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {post.data.categories.map((category: string) => (
          <span class="rounded-full bg-light px-3 py-1 text-xs font-semibold uppercase tracking-wide text-text">
            {category}
          </span>
        ))}
      </div>
    )
  }
  <h2 class="h3 mb-2 mt-4">
    <a href={`/blog/${post.id}`} class="block hover:text-primary">
      {post.data.title}
    </a>
  </h2>
  <p set:html={plainify(post.body.slice(0, summary_length))} />
  <a class="btn btn-primary mt-4" href={`/blog/${post.id}`}> Read More </a>
</div>
