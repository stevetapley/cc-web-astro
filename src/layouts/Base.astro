---
import PostHogAnalytics from "@/components/PostHogAnalytics.astro";
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import "@/styles/main.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

// font families - extract font names for Font component (filter out type keys)
const fontEntries = Object.entries(theme.fonts.font_family).filter(
  ([key]) => !key.includes("_type"),
);

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  og_type?: "website" | "article";
  article_published_time?: string;
  article_section?: string;
  article_tags?: string[];
  structured_data?: Record<string, unknown> | Array<Record<string, unknown>>;
}

// destructure frontmatter
const {
  title,
  meta_title,
  description,
  image,
  noindex,
  canonical,
  og_type = "website",
  article_published_time,
  article_section,
  article_tags = [],
  structured_data,
} = Astro.props;

const siteTitle = plainify(config.site.title);
const resolvedTitle = plainify(
  meta_title ? meta_title : title ? `${title} | ${siteTitle}` : siteTitle,
);
const resolvedDescription = plainify(
  description ? description : config.metadata.meta_description,
);
const canonicalUrl = canonical
  ? canonical
  : new URL(Astro.url.pathname, config.site.base_url).toString();
const socialImage = `${config.site.base_url}${
  image ? image : config.metadata.meta_image
}`;
const siteUrl = config.site.base_url.replace(/\/$/, "");
const siteHostname = new URL(siteUrl).hostname;
const organizationId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;
const organizationDescription = plainify(config.metadata.meta_description);
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@id": organizationId,
  "@type": "Organization",
  name: siteTitle,
  alternateName: siteHostname,
  description: organizationDescription,
  url: siteUrl,
  logo: `${siteUrl}${config.site.logo}`,
};
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@id": websiteId,
  "@type": "WebSite",
  name: siteTitle,
  url: siteUrl,
  publisher: {
    "@id": organizationId,
  },
  inLanguage: "en",
};
const pageStructuredData = structured_data
  ? Array.isArray(structured_data)
    ? structured_data
    : [structured_data]
  : [];
const pageStructuredDataTypes = new Set(
  pageStructuredData
    .flatMap((item) => {
      const typeValue = item["@type"];
      return Array.isArray(typeValue) ? typeValue : [typeValue];
    })
    .filter((typeValue): typeValue is string => typeof typeValue === "string"),
);
const hasPrimaryPageSchema = [
  "WebPage",
  "AboutPage",
  "CollectionPage",
  "ContactPage",
  "FAQPage",
  "BlogPosting",
  "PrivacyPolicy",
].some((schemaType) => pageStructuredDataTypes.has(schemaType));
const defaultWebPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: resolvedTitle,
  description: resolvedDescription,
  url: canonicalUrl,
  isPartOf: {
    "@id": websiteId,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- favicons -->
    <link rel="icon" href="/images/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <link rel="manifest" href="/images/site.webmanifest" />
    <!-- theme meta -->
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css - Astro 6 built-in Font API -->
    {
      fontEntries.map(([key]) => {
        const cssVar = `--font-${key}` as any;
        return <Font cssVariable={cssVar} preload />;
      })
    }

    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>{resolvedTitle}</title>

    <!-- canonical url -->
    <link rel="canonical" href={canonicalUrl} item-prop="url" />

    <!-- noindex robots -->
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />

    <!-- meta-description -->
    <meta name="description" content={resolvedDescription} />

    <ClientRouter />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og-title -->
    <meta property="og:title" content={resolvedTitle} />

    <!-- og-description -->
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content={og_type} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:url" content={canonicalUrl} />
    {
      og_type === "article" && article_published_time && (
        <meta property="article:published_time" content={article_published_time} />
      )
    }
    {
      og_type === "article" && article_section && (
        <meta property="article:section" content={article_section} />
      )
    }
    {
      og_type === "article" &&
        article_tags.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <!-- twitter-title -->
    <meta name="twitter:title" content={resolvedTitle} />

    <!-- twitter-description -->
    <meta name="twitter:description" content={resolvedDescription} />

    <!-- og-image -->
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={resolvedTitle} />

    <!-- twitter-image -->
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={resolvedTitle} />
    <meta name="twitter:site" content="@careerclarityapp" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    {
      !hasPrimaryPageSchema && (
        <script type="application/ld+json" set:html={JSON.stringify(defaultWebPageJsonLd)} />
      )
    }
    {
      pageStructuredData.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body>
    <TwSizeIndicator />
    <Header />
    <main id="main-content" class="site-main">
      <slot />
    </main>
    <Footer />
    <PostHogAnalytics />
  </body>
</html>
